---
import { withBase } from '../i18n/ui';

interface GalleryItem { image: string; focal: string; }

interface Props {
  images: GalleryItem[];
  title?: string;
}

const { images, title } = Astro.props;
---

{images.length > 0 && (
  <section class="gallery">
    {title && <h2 class="section-title">{title}</h2>}
    <ul class="gallery__grid">
      {images.map((item) => {
        const href = withBase(item.image);
        return (
          <li class="gallery__item">
            <a href={href} target="_blank" rel="noopener noreferrer">
              <img src={href} alt="" loading="lazy"
                style={`object-position:${item.focal ?? '50% 50%'}`} />
            </a>
          </li>
        );
      })}
    </ul>
  </section>
)}
