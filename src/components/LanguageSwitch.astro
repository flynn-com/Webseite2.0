---
import { languages, withBase, stripBase, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const currentPath = Astro.url.pathname;

function buildAltPath(path: string, target: Lang): string {
  const normalized = stripBase(path.endsWith('/') ? path : path + '/');

  const staticMap: Record<string, { de: string; en: string }> = {
    home: { de: '/', en: '/en/' },
    projects: { de: '/projekte/', en: '/en/projects/' },
    about: { de: '/ueber-mich/', en: '/en/about/' },
    imprint: { de: '/impressum/', en: '/en/imprint/' },
    privacy: { de: '/datenschutz/', en: '/en/privacy/' },
  };

  for (const entry of Object.values(staticMap)) {
    if (entry.de === normalized || entry.en === normalized) return withBase(entry[target]);
  }

  if (normalized.startsWith('/projekte/') || normalized.startsWith('/en/projects/')) {
    return withBase(staticMap.projects[target]);
  }

  return withBase(staticMap.home[target]);
}
---

<ul class="lang-switch" aria-label="Language">
  {(Object.keys(languages) as Lang[]).map((code) => {
    const isActive = code === lang;
    return (
      <li>
        <a
          href={buildAltPath(currentPath, code)}
          hreflang={code}
          aria-current={isActive ? 'true' : undefined}
        >{code.toUpperCase()}</a>
      </li>
    );
  })}
</ul>
