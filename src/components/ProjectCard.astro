---
import { projectDetailPath, withBase, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
  slug: string;
  title: string;
  category: string;
  cover: string;
  description?: string;
  location?: string;
  gallery?: string[];
  date: Date;
  index: number;
  total: number;
}

const {
  lang, slug, title, category, cover,
  description, location, gallery = [],
  date, index, total,
} = Astro.props;

// Bilder: Titelbild immer zuerst, dann Galerie-Bilder (ohne Duplikat)
const images: string[] = [
  ...(cover ? [cover] : []),
  ...gallery.filter(img => img !== cover),
];
const hasCarousel = images.length > 1;

// Nummer-Formatierung: 01 / 05
const numCurrent = String(index + 1).padStart(2, '0');
const numTotal   = String(total).padStart(2, '0');

const detailHref = projectDetailPath(lang, slug);
---

<article class="proj-card">

  <!-- ── Linke Glas-Spalte ── -->
  <div class="proj-card__glass-col">
    <p class="proj-card__number" aria-label={`Projekt ${numCurrent} von ${numTotal}`}>
      <strong>{numCurrent}</strong><span>/{numTotal}</span>
    </p>
    {location && <p class="proj-card__location">{location}</p>}
  </div>

  <!-- ── Mittlere Info-Spalte (schwarz) ── -->
  <div class="proj-card__info">
    <div class="proj-card__info-inner">
      <h3 class="proj-card__title">{title}</h3>
      {description && <p class="proj-card__desc">{description}</p>}
    </div>
    <a class="proj-card__cta" href={detailHref}>{lang === 'de' ? 'ZUM PROJEKT' : 'VIEW MORE'}</a>
  </div>

  <!-- ── Rechtes Bild-Karussell ── -->
  <div class="proj-card__media" data-carousel>
    <div class="proj-card__slides">
      {images.map((src, i) => (
        <img
          class={`proj-card__slide${i === 0 ? ' is-active' : ''}`}
          src={withBase(src)}
          alt={i === 0 ? title : ''}
          loading={i === 0 ? 'eager' : 'lazy'}
          draggable="false"
        />
      ))}
    </div>

    {hasCarousel && (
      <>
        <button class="proj-card__nav proj-card__nav--prev" aria-label="Vorheriges Bild" type="button">
          &#8249;
        </button>
        <button class="proj-card__nav proj-card__nav--next" aria-label="Nächstes Bild" type="button">
          &#8250;
        </button>
        <div class="proj-card__dots">
          {images.map((_, i) => (
            <button
              class={`proj-card__dot${i === 0 ? ' is-active' : ''}`}
              aria-label={`Bild ${i + 1}`}
              type="button"
              data-index={i}
            />
          ))}
        </div>
      </>
    )}
  </div>

</article>

<script>
  document.querySelectorAll<HTMLElement>('[data-carousel]').forEach(carousel => {
    const slides = carousel.querySelectorAll<HTMLElement>('.proj-card__slide');
    const dots   = carousel.querySelectorAll<HTMLElement>('.proj-card__dot');
    const prev   = carousel.querySelector<HTMLButtonElement>('.proj-card__nav--prev');
    const next   = carousel.querySelector<HTMLButtonElement>('.proj-card__nav--next');
    if (slides.length < 2) return;

    let current = 0;

    function goTo(n: number) {
      slides[current].classList.remove('is-active');
      dots[current]?.classList.remove('is-active');
      current = (n + slides.length) % slides.length;
      slides[current].classList.add('is-active');
      dots[current]?.classList.add('is-active');
    }

    // Pfeil-Buttons (Desktop/Tablet)
    prev?.addEventListener('click', () => goTo(current - 1));
    next?.addEventListener('click', () => goTo(current + 1));

    // Dot-Navigation
    dots.forEach(dot => {
      dot.addEventListener('click', () => goTo(Number(dot.dataset.index)));
    });

    // Touch-Swipe (Mobile)
    let touchStartX = 0;
    let touchStartY = 0;

    carousel.addEventListener('touchstart', (e: TouchEvent) => {
      touchStartX = e.touches[0].clientX;
      touchStartY = e.touches[0].clientY;
    }, { passive: true });

    carousel.addEventListener('touchend', (e: TouchEvent) => {
      const dx = e.changedTouches[0].clientX - touchStartX;
      const dy = e.changedTouches[0].clientY - touchStartY;
      // Nur auslösen wenn horizontale Bewegung dominiert (kein versehentliches Scrollen)
      if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 40) {
        goTo(dx < 0 ? current + 1 : current - 1);
      }
    }, { passive: true });
  });
</script>
