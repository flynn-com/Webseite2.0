---
import { pathForLang, withBase, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const aboutLabel = lang === 'de' ? '\u00dcBER MICH' : 'ABOUT';
const contactLabel = lang === 'de' ? 'KONTAKT' : 'CONTACT';
const scrollLabel = lang === 'de' ? 'Nach unten scrollen' : 'Scroll down';
---

<section class="hero-flynn" aria-label="Flynn Bertsch">
  <!-- Layer 1: Gradient-Hintergrund (scrollt normal mit) -->
  <div class="hero-flynn__bg" aria-hidden="true"></div>

  <!-- Navigation (zwei Glas-Buttons, scrollen mit) -->
  <nav class="hero-flynn__nav" aria-label="Hauptnavigation">
    <a class="glass-btn glass-btn--pill" href="mailto:kontakt@example.com">
      <span>{contactLabel}</span>
    </a>
    <a class="glass-btn glass-btn--pill" href={pathForLang(lang, 'about')}>
      <span>{aboutLabel}</span>
    </a>
  </nav>

  <!-- Logo FLYNN (scrollt normal mit) -->
  <img class="hero-flynn__logo" src={withBase('/uploads/hero/logo-flynn.png')} alt="FLYNN" />

  <!-- Glas-Pfeil (Scroll-Hinweis, scrollt mit) -->
  <button
    type="button"
    class="glass-btn glass-btn--round hero-flynn__scroll"
    aria-label={scrollLabel}
  >
    <img src={withBase('/uploads/hero/arrow.png')} alt="" aria-hidden="true" />
  </button>

  <!-- Layer 3: Frau (sticky, bleibt am Viewport-Rand) -->
  <div class="hero-flynn__woman-stage" aria-hidden="true">
    <img
      class="hero-flynn__woman"
      src={withBase('/uploads/hero/woman.png')}
      alt=""
    />
  </div>
</section>

<script>
  const hero = document.querySelector<HTMLElement>('.hero-flynn');
  const scrollBtn = hero?.querySelector<HTMLButtonElement>('.hero-flynn__scroll');

  scrollBtn?.addEventListener('click', () => {
    window.scrollTo({ top: window.innerHeight, behavior: 'smooth' });
  });
</script>
