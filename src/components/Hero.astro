---
import { pathForLang, withBase, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const buttonLabel = lang === 'de' ? '\u00fcber mich' : 'about me';
const scrollLabel = lang === 'de' ? 'Nach unten scrollen' : 'Scroll down';
---

<section class="hero-flynn" aria-label="Flynn Bertsch">
  <!-- Layer 1: Hintergrund (Himmel) -->
  <picture class="hero-flynn__bg">
    <source media="(max-width: 767px)" srcset={withBase('/uploads/hero/sky-H.png')} />
    <img src={withBase('/uploads/hero/sky-Q.png')} alt="" aria-hidden="true" />
  </picture>

  <!-- Layer 2: Logo FLYNN (Desktop/Tablet: Mitte, Mobile: oberste Ebene) -->
  <img
    class="hero-flynn__logo"
    src={withBase('/uploads/hero/logo-flynn.png')}
    alt="FLYNN"
  />

  <!-- Layer 3: Frau Cutout (Desktop/Tablet: oberste Ebene, Mobile: darunter) -->
  <img
    class="hero-flynn__woman"
    src={withBase('/uploads/hero/woman.png')}
    alt=""
    aria-hidden="true"
  />

  <!-- Glas-Button -->
  <a class="glass-btn hero-flynn__cta" href={pathForLang(lang, 'about')}>
    <span>{buttonLabel}</span>
  </a>

  <!-- Glas-Pfeil (Scroll-Hinweis) -->
  <button
    type="button"
    class="glass-btn glass-btn--round hero-flynn__scroll"
    aria-label={scrollLabel}
  >
    <img src={withBase('/uploads/hero/arrow.png')} alt="" aria-hidden="true" />
  </button>
</section>

<script>
  const scrollBtn = document.querySelector<HTMLButtonElement>('.hero-flynn__scroll');
  scrollBtn?.addEventListener('click', () => {
    window.scrollTo({ top: window.innerHeight, behavior: 'smooth' });
  });
</script>
