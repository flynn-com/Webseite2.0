---
import { pathForLang, withBase, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const buttonLabel = lang === 'de' ? '\u00fcber mich' : 'about me';
---

<section class="hero-flynn" aria-label="Flynn Bertsch">
  <picture class="hero-flynn__picture">
    <source
      media="(max-width: 767px)"
      srcset={withBase('/uploads/hero/hero-mobile.jpg')}
    />
    <source
      media="(max-width: 1023px)"
      srcset={withBase('/uploads/hero/hero-tablet.jpg')}
    />
    <img
      class="hero-flynn__img"
      src={withBase('/uploads/hero/hero-desktop.jpg')}
      alt="Flynn Bertsch"
      fetchpriority="high"
    />
  </picture>

  <!-- Unsichtbare Klickfl\u00e4che \u00fcber dem \u201e\u00fcber mich\u201c-Button im Bild -->
  <a
    class="hero-flynn__btn-overlay"
    href={pathForLang(lang, 'about')}
    aria-label={buttonLabel}
  >
    <span class="visually-hidden">{buttonLabel}</span>
  </a>
</section>
