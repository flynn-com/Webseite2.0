---
import { pathForLang, withBase, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const aboutLabel = lang === 'de' ? '\u00dcBER MICH' : 'ABOUT';
const contactLabel = lang === 'de' ? 'KONTAKT' : 'CONTACT';
const scrollLabel = lang === 'de' ? 'Nach unten scrollen' : 'Scroll down';
---

<div class="hero-flynn-wrap">
<section class="hero-flynn" aria-label="Flynn Bertsch">
  <!-- Layer 1: Hintergrund -->
  <picture class="hero-flynn__bg">
    <source media="(max-width: 767px)" srcset={withBase('/uploads/hero/sky-H.png')} />
    <img src={withBase('/uploads/hero/sky-Q.png')} alt="" aria-hidden="true" />
  </picture>

  <!-- Layer 2: Logo FLYNN -->
  <img class="hero-flynn__logo" src={withBase('/uploads/hero/logo-flynn.png')} alt="FLYNN" />

  <!-- Layer 3: Frau (Cutout) -->
  <img
    class="hero-flynn__woman"
    src={withBase('/uploads/hero/woman.png')}
    alt=""
    aria-hidden="true"
  />

  <!-- Navigation (zwei Glas-Buttons am oberen Rand) -->
  <nav class="hero-flynn__nav" aria-label="Hauptnavigation">
    <a class="glass-btn glass-btn--pill" href="mailto:kontakt@example.com">
      <span>{contactLabel}</span>
    </a>
    <a class="glass-btn glass-btn--pill" href={pathForLang(lang, 'about')}>
      <span>{aboutLabel}</span>
    </a>
  </nav>

  <!-- Glas-Pfeil (Scroll-Hinweis) -->
  <button
    type="button"
    class="glass-btn glass-btn--round hero-flynn__scroll"
    aria-label={scrollLabel}
  >
    <img src={withBase('/uploads/hero/arrow.png')} alt="" aria-hidden="true" />
  </button>
</section>
</div>

<script>
  const wrap = document.querySelector<HTMLElement>('.hero-flynn-wrap');
  const hero = wrap?.querySelector<HTMLElement>('.hero-flynn');
  const woman = hero?.querySelector<HTMLElement>('.hero-flynn__woman');
  const logo = hero?.querySelector<HTMLElement>('.hero-flynn__logo');
  const scrollBtn = hero?.querySelector<HTMLButtonElement>('.hero-flynn__scroll');

  scrollBtn?.addEventListener('click', () => {
    window.scrollTo({ top: window.innerHeight, behavior: 'smooth' });
  });

  if (wrap && hero && woman && logo) {
    const mqlMobile = window.matchMedia('(max-width: 767px)');
    const mqlReduced = window.matchMedia('(prefers-reduced-motion: reduce)');

    const getTopLayer = () => (mqlMobile.matches ? logo : woman);

    let ticking = false;
    function onScroll() {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        // Scrolled-through-Wrapper: vom Top des Wrappers bis zum Top des Hero-Bereichs
        const wrapRect = wrap!.getBoundingClientRect();
        const scrolled = Math.max(0, -wrapRect.top);
        const range = Math.max(1, wrap!.offsetHeight - hero!.offsetHeight);
        const progress = Math.min(1, scrolled / range);
        hero!.style.setProperty('--hero-scroll', progress.toFixed(3));
        ticking = false;
      });
    }

    function activate() {
      hero!.classList.add('is-ready');
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    }

    if (mqlReduced.matches) {
      activate();
    } else {
      // Sobald die Entrance-Animation fertig ist \u2192 Scroll-Logik aktivieren
      getTopLayer().addEventListener('animationend', activate, { once: true });
      // Sicherheits-Fallback
      setTimeout(() => {
        if (!hero!.classList.contains('is-ready')) activate();
      }, 3000);
    }

    // Bei Viewport-Wechsel (z.\u202fB. Ger\u00e4tedrehung) ggf. neu binden
    mqlMobile.addEventListener('change', () => {
      if (hero!.classList.contains('is-ready')) onScroll();
    });
  }
</script>
