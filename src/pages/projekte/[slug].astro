---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import YouTubeEmbed from '../../components/YouTubeEmbed.astro';
import LocalVideo from '../../components/LocalVideo.astro';
import { t, pathForLang, withBase } from '../../i18n/ui';

export async function getStaticPaths() {
  const entries = await getCollection('projects-de', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

interface Props { entry: CollectionEntry<'projects-de'>; }
const { entry } = Astro.props;
const { Content } = await render(entry);
const lang = 'de' as const;

const galleryImages = entry.data.gallery.filter(img => img !== entry.data.cover);
const totalImages = (entry.data.cover ? 1 : 0) + galleryImages.length;

// Andere Projekte (aktuelles ausschließen, nach order sortieren)
const allProjects = await getCollection('projects-de', ({ data }) => !data.draft);
const otherProjects = allProjects
  .filter(p => p.id !== entry.id)
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout lang={lang} title={`${entry.data.title} – Flynn Bertsch`} description={entry.data.description}>
<div class="pd-page">

  <!-- ── Zurück ── -->
  <a class="pd-back" href={pathForLang(lang, 'projects')}>← {t(lang, 'project.back')}</a>

  <!-- ══════════════════════════════════════════════════
       PROJEKT-KARTE — vertikal (Startseiten-Card 90° gedreht)
       Zeile 1: Glass  |  Zeile 2: Bild  |  Zeile 3: Schwarz
       ══════════════════════════════════════════════════ -->
  <div class="pd-card">

    <!-- Zeile 1: Glass-Panel — Titel links oben, Zahl rechts unten -->
    <div class="pd-card__glass proj-card__glass-col">
      <h1 class="pd-card__title">{entry.data.title}</h1>
      <div class="pd-card__glass-bottom">
        <p class="proj-card__number pd-card__number">
          <strong>01</strong><span>/{String(totalImages).padStart(2, '0')}</span>
        </p>
        {entry.data.location && <p class="proj-card__location pd-card__location">{entry.data.location}</p>}
      </div>
    </div>

    <!-- Zeile 2: Cover-Bild (= rechte Bild-Spalte der Startseitenkarte) -->
    {entry.data.cover && (
      <div class="pd-card__media">
        <img src={withBase(entry.data.cover)} alt={entry.data.title} style={`object-position: ${entry.data.cover_focal}`} />
      </div>
    )}

    <!-- Zeile 3: Schwarz-Panel (= mittlere schwarze Spalte der Startseitenkarte) -->
    <div class="pd-card__info proj-card__info">
      {entry.data.description && (
        <p class="proj-card__desc">{entry.data.description}</p>
      )}
      <div class="pd-card__body prose">
        <Content />
      </div>
    </div>

  </div>

  <!-- ══════════════════════════════════════════════════
       GALERIE — kein Border-Radius, 24px Abstand
       ══════════════════════════════════════════════════ -->
  {(galleryImages.length > 0 || entry.data.videos.length > 0 || entry.data.videos_portrait.length > 0 || entry.data.youtube.length > 0) && (
    <section class="pd-gallery">

      {galleryImages.map((src, i) => {
        const focal = entry.data.gallery_focal[i] ?? 'center';
        return (
          <button class="pd-gallery__item" data-src={withBase(src)} type="button">
            <img src={withBase(src)} alt="" loading="lazy" style={`object-position: ${focal}`} />
          </button>
        );
      })}

      {entry.data.videos.map((src) => (
        <div class="pd-gallery__item pd-gallery__item--video">
          <LocalVideo src={src} />
        </div>
      ))}

      {entry.data.videos_portrait.map((src) => (
        <div class="pd-gallery__item pd-gallery__item--video-portrait">
          <LocalVideo src={src} />
        </div>
      ))}

      {entry.data.youtube.map((url) => (
        <div class="pd-gallery__item pd-gallery__item--video">
          <YouTubeEmbed url={url} lang={lang} />
        </div>
      ))}

    </section>
  )}

  <!-- ══════════════════════════════════════════════════
       WEITERE PROJEKTE
       ══════════════════════════════════════════════════ -->
  {otherProjects.length > 0 && (
    <section class="pd-more">
      <h2 class="pd-more__heading">Weitere Projekte</h2>
      <div class="pd-more__grid">
        {otherProjects.map((p) => (
            <a class="pd-more__card" href={`/Webseite2.0/projekte/${p.id}`}>
              {/* Glass-Zeile */}
              <div class="pd-more__glass proj-card__glass-col">
                <span class="pd-more__title">{p.data.title}</span>
                <span class="pd-more__num">
                  <strong>{String(p.data.order).padStart(2, '0')}</strong>
                  <span>/{String(allProjects.length).padStart(2, '0')}</span>
                </span>
              </div>
              {/* Bild */}
              <div class="pd-more__img">
                <img src={withBase(p.data.cover)} alt={p.data.title} loading="lazy" />
              </div>
            </a>
        ))}
      </div>
    </section>
  )}

  <!-- ── Lightbox ── -->
  <div class="pd-lightbox" id="pdLightbox" aria-hidden="true">
    <button class="pd-lightbox__close" id="pdLightboxClose" aria-label="Schließen">✕</button>
    <img class="pd-lightbox__img" id="pdLightboxImg" src="" alt="" />
  </div>

</div>{/* pd-page */}
</BaseLayout>

<script>
  const lightbox = document.getElementById('pdLightbox') as HTMLElement;
  const lbImg    = document.getElementById('pdLightboxImg') as HTMLImageElement;
  const lbClose  = document.getElementById('pdLightboxClose') as HTMLButtonElement;

  document.querySelectorAll<HTMLButtonElement>('.pd-gallery__item:not(.pd-gallery__item--video)').forEach(btn => {
    btn.addEventListener('click', () => {
      lbImg.src = btn.dataset.src ?? '';
      lightbox.setAttribute('aria-hidden', 'false');
      lightbox.classList.add('is-open');
    });
  });

  function closeLightbox() {
    lightbox.setAttribute('aria-hidden', 'true');
    lightbox.classList.remove('is-open');
  }

  lbClose.addEventListener('click', closeLightbox);
  lightbox.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLightbox(); });
</script>
