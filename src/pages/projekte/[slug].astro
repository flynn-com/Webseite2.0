---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import YouTubeEmbed from '../../components/YouTubeEmbed.astro';
import LocalVideo from '../../components/LocalVideo.astro';
import { t, pathForLang, withBase } from '../../i18n/ui';

export async function getStaticPaths() {
  const entries = await getCollection('projects-de', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

interface Props { entry: CollectionEntry<'projects-de'>; }
const { entry } = Astro.props;
const { Content } = await render(entry);
const lang = 'de' as const;

const galleryImages = entry.data.gallery.filter(img => img !== entry.data.cover);
const totalImages   = (entry.data.cover ? 1 : 0) + galleryImages.length;

// Bilder den Layout-Slots zuweisen (Figma-Reihenfolge)
const topThumbs  = galleryImages.slice(0, 2);   // 2 kleine Bilder oben rechts
const fullImg    = galleryImages[2] ?? null;      // Breitbild Mitte
const splitImg   = galleryImages[3] ?? null;      // Bild im Text-Split
const bottomPair = galleryImages.slice(4, 6);     // 2 Bilder unten
const extraImgs  = galleryImages.slice(6);        // übrige Bilder

// Andere Projekte
const allProjects   = await getCollection('projects-de', ({ data }) => !data.draft);
const otherProjects = allProjects
  .filter(p => p.data.slug !== entry.data.slug)
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout lang={lang} title={`${entry.data.title} – Flynn Bertsch`} description={entry.data.description}>
<div class="pd-page">

  <!-- Zurück -->
  <a class="pd-back" href={pathForLang(lang, 'projects')}>{t(lang, 'project.back')}</a>

  <!-- ══ HAUPT-LAYOUT ══ -->
  <div class="pd-layout">

    <!-- ── Header: Titel | Location | Zähler ── -->
    <header class="pd-header">
      <h1 class="pd-header__title">{entry.data.title}</h1>
      {entry.data.location && <span class="pd-header__location">{entry.data.location}</span>}
      <p class="pd-header__counter">
        <strong>01</strong><span>/{String(totalImages).padStart(2, '0')}</span>
      </p>
    </header>

    <!-- ── Top-Block: Großes Bild links + Text & 2 Bilder rechts ── -->
    <div class="pd-top">

      {entry.data.cover && (
        <div class="pd-img pd-top__main">
          <img
            src={withBase(entry.data.cover)}
            alt={entry.data.title}
            style={`object-position:${entry.data.cover_focal}`}
          />
        </div>
      )}

      <div class="pd-top__right">
        {entry.data.description && (
          <p class="pd-text">{entry.data.description}</p>
        )}
        {topThumbs.length > 0 && (
          <div class="pd-thumbs">
            {topThumbs.map((src, i) => (
              <button class="pd-img" data-src={withBase(src)} type="button">
                <img
                  src={withBase(src)}
                  alt=""
                  loading="lazy"
                  style={`object-position:${entry.data.gallery_focal[i] ?? 'center'}`}
                />
              </button>
            ))}
          </div>
        )}
      </div>
    </div>

    <!-- ── Breitbild Mitte ── -->
    {fullImg && (
      <button class="pd-img pd-full" data-src={withBase(fullImg)} type="button">
        <img
          src={withBase(fullImg)}
          alt=""
          loading="lazy"
          style={`object-position:${entry.data.gallery_focal[2] ?? 'center'}`}
        />
      </button>
    )}

    <!-- ── Split: Text links + Bild rechts ── -->
    {(splitImg || true) && (
      <div class="pd-split">
        <div class="pd-text pd-split__text prose">
          <Content />
        </div>
        {splitImg && (
          <button class="pd-img pd-split__img" data-src={withBase(splitImg)} type="button">
            <img
              src={withBase(splitImg)}
              alt=""
              loading="lazy"
              style={`object-position:${entry.data.gallery_focal[3] ?? 'center'}`}
            />
          </button>
        )}
      </div>
    )}

    <!-- ── Unteres Bildpaar ── -->
    {bottomPair.length > 0 && (
      <div class="pd-pair">
        {bottomPair.map((src, i) => (
          <button class="pd-img" data-src={withBase(src)} type="button">
            <img
              src={withBase(src)}
              alt=""
              loading="lazy"
              style={`object-position:${entry.data.gallery_focal[4 + i] ?? 'center'}`}
            />
          </button>
        ))}
      </div>
    )}

    <!-- ── Übrige Bilder ── -->
    {extraImgs.length > 0 && (
      <div class="pd-extra">
        {extraImgs.map((src, i) => (
          <button class="pd-img" data-src={withBase(src)} type="button">
            <img
              src={withBase(src)}
              alt=""
              loading="lazy"
              style={`object-position:${entry.data.gallery_focal[6 + i] ?? 'center'}`}
            />
          </button>
        ))}
      </div>
    )}

    <!-- ── Videos ── -->
    {entry.data.videos.map((src) => (
      <div class="pd-img pd-video">
        <LocalVideo src={src} />
      </div>
    ))}
    {entry.data.videos_portrait.map((src) => (
      <div class="pd-img pd-video pd-video--portrait">
        <LocalVideo src={src} />
      </div>
    ))}
    {entry.data.youtube.map((url) => (
      <div class="pd-img pd-video">
        <YouTubeEmbed url={url} lang={lang} />
      </div>
    ))}

    <!-- ── Branding ── -->
    <div class="pd-brand">*FLYNN</div>

  </div>{/* pd-layout */}

  <!-- ══ WEITERE PROJEKTE ══ -->
  {otherProjects.length > 0 && (
    <section class="pd-more">
      <h2 class="pd-more__heading">Weitere Projekte</h2>
      <div class="pd-more__grid">
        {otherProjects.map((p) => (
          <a class="pd-more__card" href={`/Webseite2.0/projekte/${p.data.slug}`}>
            <div class="pd-more__glass proj-card__glass-col">
              <span class="pd-more__title">{p.data.title}</span>
              <span class="pd-more__num">
                <strong>{String(p.data.order).padStart(2, '0')}</strong>
                <span>/{String(allProjects.length).padStart(2, '0')}</span>
              </span>
            </div>
            <div class="pd-more__img">
              <img src={withBase(p.data.cover)} alt={p.data.title} loading="lazy" />
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- ── Lightbox ── -->
  <div class="pd-lightbox" id="pdLightbox" aria-hidden="true">
    <button class="pd-lightbox__close" id="pdLightboxClose" aria-label="Schließen">✕</button>
    <img class="pd-lightbox__img" id="pdLightboxImg" src="" alt="" />
  </div>

</div>{/* pd-page */}
</BaseLayout>

<script>
  const lightbox = document.getElementById('pdLightbox') as HTMLElement;
  const lbImg    = document.getElementById('pdLightboxImg') as HTMLImageElement;
  const lbClose  = document.getElementById('pdLightboxClose') as HTMLButtonElement;

  document.querySelectorAll<HTMLButtonElement>('button.pd-img[data-src]').forEach(btn => {
    btn.addEventListener('click', () => {
      lbImg.src = btn.dataset.src ?? '';
      lightbox.setAttribute('aria-hidden', 'false');
      lightbox.classList.add('is-open');
    });
  });

  function closeLightbox() {
    lightbox.setAttribute('aria-hidden', 'true');
    lightbox.classList.remove('is-open');
  }

  lbClose.addEventListener('click', closeLightbox);
  lightbox.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLightbox(); });
</script>
