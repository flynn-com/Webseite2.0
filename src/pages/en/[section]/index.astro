---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ProjectCard from '../../../components/ProjectCard.astro';
import { t, pathForLang } from '../../../i18n/ui';
import pageRoutes from '../../../data/page-routes.json';

export async function getStaticPaths() {
  return [{ params: { section: pageRoutes.en.projects } }];
}

const lang = 'en' as const;
const projects = (await getCollection('projects-en', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);

const total = projects.length;
const categories = ['all', 'fotografie', 'video', 'webdesign', 'design'] as const;
---

<BaseLayout lang={lang} title={`${t(lang, 'projects.title')} – Flynn Bertsch`}>

  <section class="projects-page-heading">
    <a class="projects-page-heading__home" href={pathForLang(lang, 'home')}>
      &#8592; Home
    </a>
    <h1>PROJECTS</h1>
  </section>

  <section class="projects-section">

    <div class="filter-bar" role="group" aria-label="Filter">
      {categories.map((cat) => (
        <button
          class={`filter-bar__btn${cat === 'all' ? ' is-active' : ''}`}
          type="button"
          data-filter={cat}
          aria-pressed={cat === 'all' ? 'true' : 'false'}
        >{t(lang, `projects.filter.${cat}` as any)}</button>
      ))}
    </div>

    {projects.length === 0 ? (
      <p style="color:#fff;">{t(lang, 'projects.empty')}</p>
    ) : (
      <div class="project-grid" id="project-grid">
        {projects.map((p, i) => (
          <div class="project-grid__item" data-category={p.data.category}>
            <ProjectCard
              lang={lang}
              slug={p.data.slug}
              title={p.data.title}
              category={p.data.category}
              cover={p.data.cover}
              description={p.data.description}
              location={p.data.location}
              gallery={p.data.gallery}
              date={p.data.date ?? new Date()}
              index={i}
              total={total}
            />
          </div>
        ))}
      </div>
    )}
  </section>

</BaseLayout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-bar__btn');
  const items   = document.querySelectorAll<HTMLElement>('.project-grid__item');

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter;
      buttons.forEach((b) => {
        b.setAttribute('aria-pressed', String(b === btn));
        b.classList.toggle('is-active', b === btn);
      });
      items.forEach((item) => {
        const show = filter === 'all' || item.dataset.category === filter;
        item.style.display = show ? '' : 'none';
      });
    });
  });
</script>
