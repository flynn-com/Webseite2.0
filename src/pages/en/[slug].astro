---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import pageRoutes from '../../data/page-routes.json';
import { pathForLang } from '../../i18n/ui';

type PageType = 'about' | 'imprint' | 'privacy' | 'contact';

interface Props {
  page: PageType;
  contactEntry: CollectionEntry<'contact-en'> | null;
  imprintEntry: CollectionEntry<'imprint-en'> | null;
  privacyEntry: CollectionEntry<'privacy-en'> | null;
}

export async function getStaticPaths() {
  const contactEntries = await getCollection('contact-en');
  const contactEntry = contactEntries[0] ?? null;
  const imprintEntries = await getCollection('imprint-en');
  const imprintEntry = imprintEntries[0] ?? null;
  const privacyEntries = await getCollection('privacy-en');
  const privacyEntry = privacyEntries[0] ?? null;

  return [
    { params: { slug: pageRoutes.en.about },   props: { page: 'about'   as PageType, contactEntry: null, imprintEntry: null, privacyEntry: null } },
    { params: { slug: pageRoutes.en.imprint },  props: { page: 'imprint' as PageType, contactEntry: null, imprintEntry, privacyEntry: null } },
    { params: { slug: pageRoutes.en.privacy },  props: { page: 'privacy' as PageType, contactEntry: null, imprintEntry: null, privacyEntry } },
    { params: { slug: pageRoutes.en.contact },  props: { page: 'contact' as PageType, contactEntry, imprintEntry: null, privacyEntry: null } },
  ];
}

const { page, contactEntry, imprintEntry, privacyEntry } = Astro.props;

let ImprintContent: any = null;
if (page === 'imprint' && imprintEntry) {
  const rendered = await render(imprintEntry);
  ImprintContent = rendered.Content;
}

let PrivacyContent: any = null;
if (page === 'privacy' && privacyEntry) {
  const rendered = await render(privacyEntry);
  PrivacyContent = rendered.Content;
}
const lang = 'en' as const;

const pageTitles: Record<PageType, string> = {
  about:   'About – Flynn Bertsch',
  imprint: 'Imprint – Flynn Bertsch',
  privacy: 'Privacy – Flynn Bertsch',
  contact: 'Contact – Flynn Bertsch',
};
---

<BaseLayout lang={lang} title={pageTitles[page]}>

  {page === 'about' && (
    <section class="section container">
      <h1>About</h1>
      <div class="prose">
        <p>Hi, I'm Flynn Bertsch. I work as a photographer, videographer, web designer and designer. On this site I present projects from the last few years.</p>
        <p><em>This is placeholder text – replace it with your own introduction.</em></p>
        <h2>Contact</h2>
        <p>Email: <a href="mailto:kontakt@example.com">kontakt@example.com</a></p>
      </div>
    </section>
  )}

  {page === 'imprint' && (
    <div class="lp-page">
      <a class="pd2-nav" href={pathForLang(lang, 'home')}>
        <span class="pd2-nav__icon">◄</span>
        <span>Home</span>
      </a>
      <div class="lp-inner">
        <h1 class="lp-heading">Imprint</h1>
        <div class="lp-prose">
          {ImprintContent && <ImprintContent />}
        </div>
      </div>
    </div>
  )}

  {page === 'privacy' && (
    <div class="lp-page">
      <a class="pd2-nav" href={pathForLang(lang, 'home')}>
        <span class="pd2-nav__icon">◄</span>
        <span>Home</span>
      </a>
      <div class="lp-inner">
        <h1 class="lp-heading">Privacy</h1>
        <div class="lp-prose">
          {PrivacyContent && <PrivacyContent />}
        </div>
        <p class="lp-meta">Last updated: {new Date().toLocaleDateString('en-GB')}</p>
      </div>
    </div>
  )}


  {page === 'contact' && (
    <div class="ct-page">
      <a class="pd2-nav" href={pathForLang(lang, 'home')}>
        <span class="pd2-nav__icon">◄</span>
        <span>Home</span>
      </a>
      <div class="ct-inner">
        <h1 class="ct-heading">Contact</h1>
        {contactEntry?.data.subtitle && (
          <p class="ct-sub">{contactEntry.data.subtitle}</p>
        )}
        {contactEntry?.data.email && (
          <a class="ct-email" href={`mailto:${contactEntry.data.email}`}>{contactEntry.data.email}</a>
        )}
        {contactEntry && contactEntry.data.links.length > 0 && (
          <div class="ct-links">
            {contactEntry.data.links.map((link: { label: string; url: string }) => (
              <a href={link.url} target="_blank" rel="noopener" class="ct-link">{link.label} ↗</a>
            ))}
          </div>
        )}
      </div>
    </div>
  )}

</BaseLayout>
