---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import YouTubeEmbed from '../../components/YouTubeEmbed.astro';
import LocalVideo from '../../components/LocalVideo.astro';
import { t, pathForLang, projectDetailPath, withBase } from '../../i18n/ui';
import pageRoutes from '../../data/page-routes.json';

export async function getStaticPaths() {
  const entries = await getCollection('projects-de', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { section: pageRoutes.de.projects, slug: entry.data.slug },
    props: { entry },
  }));
}

interface Props { entry: CollectionEntry<'projects-de'>; }
const { entry } = Astro.props;
const { Content } = await render(entry);
const lang = 'de' as const;

const allProjects = await getCollection('projects-de', ({ data }) => !data.draft)
  .then(list => list.sort((a, b) => a.data.order - b.data.order));
const totalProjects = allProjects.length;

const galleryImages = entry.data.gallery;

type GalleryItem = { image: string; focal: string };
type GalleryRow = { type: 'land2' | 'port3' | 'land1'; images: GalleryItem[]; startIdx: number };
const galleryRows: GalleryRow[] = [];
let imgCursor = 0;
let rowIndex = 0;
while (imgCursor < galleryImages.length) {
  const isLandscape = rowIndex % 2 === 0;
  if (isLandscape) {
    const imgs = galleryImages.slice(imgCursor, imgCursor + 2);
    galleryRows.push({ type: imgs.length === 1 ? 'land1' : 'land2', images: imgs, startIdx: imgCursor });
    imgCursor += imgs.length;
  } else {
    const imgs = galleryImages.slice(imgCursor, imgCursor + 3);
    galleryRows.push({ type: 'port3', images: imgs, startIdx: imgCursor });
    imgCursor += imgs.length;
  }
  rowIndex++;
}

const otherProjects = allProjects.filter(p => p.data.slug !== entry.data.slug);
---

<BaseLayout lang={lang} title={`${entry.data.title} – Flynn Bertsch`} description={entry.data.description}>
<div class="pd2-page">

  <a class="pd2-nav" href={pathForLang(lang, 'projects')}>
    <span class="pd2-nav__icon">◄</span>
    <span>Projekte</span>
  </a>

  <div class="pd2-header">
    <h1 class="pd2-title">{entry.data.title}</h1>
    <div class="pd2-header-right">
      <p class="pd2-counter">
        <span>{String(entry.data.order).padStart(2, '0')}/</span><span class="pd2-counter__total">{String(totalProjects).padStart(2, '0')}</span>
      </p>
      {entry.data.location && <p class="pd2-location">{entry.data.location}</p>}
    </div>
  </div>

  {entry.body?.trim() ? (
    <div class="pd2-prose"><Content /></div>
  ) : entry.data.description ? (
    <div class="pd2-prose"><p>{entry.data.description}</p></div>
  ) : null}

  {entry.data.cover && (
    <div class="pd2-hero">
      <button class="pd2-img pd2-hero__btn" type="button" data-src={withBase(entry.data.cover)} aria-label="Titelbild vergrößern">
        <img src={withBase(entry.data.cover)} alt={entry.data.title}
          style={`object-position:${entry.data.cover_focal}`}
          fetchpriority="high" decoding="async" />
      </button>
    </div>
  )}

  {galleryRows.length > 0 && (
    <div class="pd2-gallery">
      {galleryRows.map((row) => (
        <div class={`pd2-row pd2-row--${row.type}`}>
          {row.images.map((item) => (
            <button class="pd2-img" data-src={withBase(item.image)} type="button">
              <img src={withBase(item.image)} alt="" loading="lazy"
                style={`object-position:${item.focal ?? '50% 50%'}`} />
            </button>
          ))}
        </div>
      ))}
    </div>
  )}

  {entry.data.videos.length > 0 && (
    <div class="pd2-gallery">
      {entry.data.videos.map((src) => (
        <div class="pd2-video"><LocalVideo src={src} /></div>
      ))}
    </div>
  )}

  {entry.data.videos_portrait.length > 0 && (
    <div class="pd2-row pd2-row--port3" style="margin-top: var(--pd2-gap);">
      {entry.data.videos_portrait.map((src) => (
        <div class="pd2-video pd2-video--portrait"><LocalVideo src={src} /></div>
      ))}
    </div>
  )}

  {entry.data.youtube.length > 0 && (
    <div class="pd2-gallery">
      {entry.data.youtube.map((url) => (
        <div class="pd2-video"><YouTubeEmbed url={url} lang={lang} /></div>
      ))}
    </div>
  )}

  {otherProjects.length > 0 && (
    <section class="pd2-more">
      <h2 class="pd2-more__heading">Weitere Projekte</h2>
      <div class="pd2-more__grid">
        {otherProjects.map((p) => (
          <a class="pd2-more__card" href={projectDetailPath(lang, p.data.slug)}>
            <div class="pd2-more__img">
              <img src={withBase(p.data.cover)} alt={p.data.title} loading="lazy" />
            </div>
            <div class="pd2-more__info">
              <span class="pd2-more__title">{p.data.title}</span>
              <span class="pd2-more__num">
                {String(p.data.order).padStart(2, '0')}/{String(totalProjects).padStart(2, '0')}
              </span>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

</div>

<div class="pd2-lightbox" id="pdLightbox" aria-hidden="true">
  <button class="pd2-lightbox__close" id="pdLightboxClose" aria-label="Schließen">✕</button>
  <button class="pd2-lightbox__nav pd2-lightbox__prev" id="pdLightboxPrev" aria-label="Vorheriges Bild">&#10094;</button>
  <button class="pd2-lightbox__nav pd2-lightbox__next" id="pdLightboxNext" aria-label="Nächstes Bild">&#10095;</button>
  <img class="pd2-lightbox__img" id="pdLightboxImg" src="" alt="" />
</div>
</BaseLayout>

<script>
  const lightbox = document.getElementById('pdLightbox') as HTMLElement;
  const lbImg    = document.getElementById('pdLightboxImg') as HTMLImageElement;
  const lbClose  = document.getElementById('pdLightboxClose') as HTMLButtonElement;
  const lbPrev   = document.getElementById('pdLightboxPrev') as HTMLButtonElement;
  const lbNext   = document.getElementById('pdLightboxNext') as HTMLButtonElement;

  // Alle anklickbaren Bilder in DOM-Reihenfolge (Hero zuerst, dann Galerie)
  const imgBtns = Array.from(document.querySelectorAll<HTMLButtonElement>('button.pd2-img[data-src]'));
  let currentIdx = 0;

  function openLightbox(idx: number) {
    currentIdx = idx;
    lbImg.src = imgBtns[idx]?.dataset.src ?? '';
    lightbox.setAttribute('aria-hidden', 'false');
    lightbox.classList.add('is-open');
    // Pfeile nur zeigen wenn mehr als 1 Bild
    const showNav = imgBtns.length > 1;
    lbPrev.style.display = showNav ? '' : 'none';
    lbNext.style.display = showNav ? '' : 'none';
  }

  function closeLightbox() {
    lightbox.setAttribute('aria-hidden', 'true');
    lightbox.classList.remove('is-open');
  }

  function showPrev() {
    currentIdx = (currentIdx - 1 + imgBtns.length) % imgBtns.length;
    lbImg.src = imgBtns[currentIdx]?.dataset.src ?? '';
  }

  function showNext() {
    currentIdx = (currentIdx + 1) % imgBtns.length;
    lbImg.src = imgBtns[currentIdx]?.dataset.src ?? '';
  }

  imgBtns.forEach((btn, i) => {
    btn.addEventListener('click', () => openLightbox(i));
  });

  lbPrev.addEventListener('click', (e) => { e.stopPropagation(); showPrev(); });
  lbNext.addEventListener('click', (e) => { e.stopPropagation(); showNext(); });
  lbClose.addEventListener('click', closeLightbox);
  lightbox.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });
  document.addEventListener('keydown', (e) => {
    if (!lightbox.classList.contains('is-open')) return;
    if (e.key === 'ArrowLeft')  showPrev();
    if (e.key === 'ArrowRight') showNext();
    if (e.key === 'Escape')     closeLightbox();
  });
</script>
