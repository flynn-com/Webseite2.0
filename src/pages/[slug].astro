---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { pathForLang, withBase } from '../i18n/ui';
import pageRoutes from '../data/page-routes.json';

type PageType = 'about' | 'imprint' | 'privacy' | 'contact';

interface Props {
  page: PageType;
  aboutEntry: CollectionEntry<'about-de'> | null;
  contactEntry: CollectionEntry<'contact-de'> | null;
  imprintEntry: CollectionEntry<'imprint-de'> | null;
  privacyEntry: CollectionEntry<'privacy-de'> | null;
}

export async function getStaticPaths() {
  const aboutEntries = await getCollection('about-de');
  const aboutEntry = aboutEntries[0] ?? null;
  const contactEntries = await getCollection('contact-de');
  const contactEntry = contactEntries[0] ?? null;
  const imprintEntries = await getCollection('imprint-de');
  const imprintEntry = imprintEntries[0] ?? null;
  const privacyEntries = await getCollection('privacy-de');
  const privacyEntry = privacyEntries[0] ?? null;

  return [
    { params: { slug: pageRoutes.de.about },   props: { page: 'about'   as PageType, aboutEntry, contactEntry: null, imprintEntry: null, privacyEntry: null } },
    { params: { slug: pageRoutes.de.imprint },  props: { page: 'imprint' as PageType, aboutEntry: null, contactEntry: null, imprintEntry, privacyEntry: null } },
    { params: { slug: pageRoutes.de.privacy },  props: { page: 'privacy' as PageType, aboutEntry: null, contactEntry: null, imprintEntry: null, privacyEntry } },
    { params: { slug: pageRoutes.de.contact },  props: { page: 'contact' as PageType, aboutEntry: null, contactEntry, imprintEntry: null, privacyEntry: null } },
  ];
}

const { page, aboutEntry, contactEntry, imprintEntry, privacyEntry } = Astro.props;
const lang = 'de' as const;

let Content: any = null;
if (page === 'about' && aboutEntry) {
  const rendered = await render(aboutEntry);
  Content = rendered.Content;
}

const pageTitles: Record<PageType, string> = {
  about:   'Über mich – Flynn Bertsch',
  imprint: 'Impressum – Flynn Bertsch',
  privacy: 'Datenschutz – Flynn Bertsch',
  contact: 'Kontakt – Flynn Bertsch',
};
---

<BaseLayout lang={lang} title={pageTitles[page]}>

  {page === 'about' && (
    <div class="am-page">
      <a class="pd2-nav" href={pathForLang(lang, 'home')}>
        <span class="pd2-nav__icon">◄</span>
        <span>Home</span>
      </a>
      <a class="am-contact-btn" href={pathForLang(lang, 'contact')}>Kontakt</a>
      <div class="am-layout">
        <div class="am-photo">
          {aboutEntry?.data.photo && (
            <img
              src={withBase(aboutEntry.data.photo)}
              alt="Flynn Bertsch"
              style={`object-position: ${aboutEntry.data.photo_focal}`}
            />
          )}
        </div>
        <div class="am-right">
          <h1 class="am-name">Flynn<br />Bertsch</h1>
          {aboutEntry?.data.subtitle && (
            <p class="am-subtitle">{aboutEntry.data.subtitle}</p>
          )}
          {aboutEntry && aboutEntry.data.skills.length > 0 && (
            <div class="am-skills">
              {aboutEntry.data.skills.map((s: string) => (
                <span class="am-skill">{s}</span>
              ))}
            </div>
          )}
          {Content && (
            <div class="am-body"><Content /></div>
          )}
        </div>
      </div>
    </div>
  )}

  {page === 'imprint' && (
    <div class="lp-page">
      <a class="pd2-nav" href={pathForLang(lang, 'home')}>
        <span class="pd2-nav__icon">◄</span>
        <span>Home</span>
      </a>
      <div class="lp-inner">
        <h1 class="lp-heading">Impressum</h1>
        <div class="lp-section">
          <p class="lp-section-title">Angaben gemäß § 5 TMG</p>
          <p class="lp-text" style="white-space: pre-line">{imprintEntry?.data.address}</p>
        </div>
        <hr class="lp-divider" />
        <div class="lp-section">
          <p class="lp-section-title">Kontakt</p>
          <p class="lp-text">E-Mail: <a href={`mailto:${imprintEntry?.data.email}`}>{imprintEntry?.data.email}</a></p>
        </div>
        <hr class="lp-divider" />
        <div class="lp-section">
          <p class="lp-section-title">Steuerliche Angaben</p>
          <p class="lp-text">{imprintEntry?.data.tax_note}</p>
        </div>
        <hr class="lp-divider" />
        <div class="lp-section">
          <p class="lp-section-title">Verantwortlich für den Inhalt nach § 18 Abs. 2 MStV</p>
          <p class="lp-text">{imprintEntry?.data.responsible}</p>
        </div>
        {imprintEntry?.data.sections.map((section: { title: string; text: string }) => (
          <>
            <hr class="lp-divider" />
            <div class="lp-section">
              <p class="lp-section-title">{section.title}</p>
              <p class="lp-text">{section.text}</p>
            </div>
          </>
        ))}
      </div>
    </div>
  )}

  {page === 'privacy' && (
    <div class="lp-page">
      <a class="pd2-nav" href={pathForLang(lang, 'home')}>
        <span class="pd2-nav__icon">◄</span>
        <span>Home</span>
      </a>
      <div class="lp-inner">
        <h1 class="lp-heading">Datenschutz</h1>
        <div class="lp-section">
          <p class="lp-section-title">1. Verantwortlicher</p>
          <p class="lp-text" style="white-space: pre-line">{privacyEntry?.data.address}</p>
          <p class="lp-text">E-Mail: <a href={`mailto:${privacyEntry?.data.email}`}>{privacyEntry?.data.email}</a></p>
        </div>
        {privacyEntry?.data.sections.map((section: { title: string; text: string }) => (
          <>
            <hr class="lp-divider" />
            <div class="lp-section">
              <p class="lp-section-title">{section.title}</p>
              <p class="lp-text">{section.text}</p>
            </div>
          </>
        ))}
        <p class="lp-meta">Stand: {new Date().toLocaleDateString('de-DE')}</p>
      </div>
    </div>
  )}

  {page === 'contact' && (
    <div class="ct-page">
      <a class="pd2-nav" href={pathForLang(lang, 'home')}>
        <span class="pd2-nav__icon">◄</span>
        <span>Home</span>
      </a>
      <div class="ct-inner">
        <h1 class="ct-heading">Kontakt</h1>
        {contactEntry?.data.subtitle && (
          <p class="ct-sub">{contactEntry.data.subtitle}</p>
        )}
        {contactEntry?.data.email && (
          <a class="ct-email" href={`mailto:${contactEntry.data.email}`}>{contactEntry.data.email}</a>
        )}
        {contactEntry && contactEntry.data.links.length > 0 && (
          <div class="ct-links">
            {contactEntry.data.links.map((link: { label: string; url: string }) => (
              <a href={link.url} target="_blank" rel="noopener" class="ct-link">{link.label} ↗</a>
            ))}
          </div>
        )}
      </div>
    </div>
  )}

</BaseLayout>
