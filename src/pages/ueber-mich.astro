---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { pathForLang, withBase } from '../i18n/ui';

const entries = await getCollection('about-de');
const entry = entries[0];
const { Content } = await render(entry);
const lang = 'de' as const;
---

<BaseLayout lang={lang} title="Über mich – Flynn Bertsch" description={entry?.data.subtitle}>
<div class="am-page">

  <!-- ── Zurück-Link ── -->
  <a class="pd2-nav" href={pathForLang(lang, 'home')}>
    <span class="pd2-nav__icon">◄</span>
    <span>Home</span>
  </a>

  <!-- ── Haupt-Layout: Foto | Rechte Spalte ── -->
  <div class="am-layout">

    <!-- ── Foto ── -->
    <div class="am-photo">
      {entry?.data.photo && (
        <img
          src={withBase(entry.data.photo)}
          alt={`Flynn Bertsch`}
          style={`object-position: ${entry.data.photo_focal}`}
        />
      )}
    </div>

    <!-- ── Rechte Spalte ── -->
    <div class="am-right">

      <!-- Riesiger Name -->
      <h1 class="am-name">
        Flynn<br />Bertsch
      </h1>

      <!-- Berufsbezeichnung -->
      {entry?.data.subtitle && (
        <p class="am-subtitle">{entry.data.subtitle}</p>
      )}

      <!-- Skill-Pills -->
      {entry?.data.skills.length > 0 && (
        <div class="am-skills">
          {entry.data.skills.map((s) => (
            <span class="am-skill">{s}</span>
          ))}
        </div>
      )}

      <!-- Fließtext -->
      {entry && (
        <div class="am-body">
          <Content />
        </div>
      )}

    </div>
  </div>

</div>
</BaseLayout>
